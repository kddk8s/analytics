#!/bin/bash
# Recommend running this with the year's candidates the the snapshot from the election
set -e -u -o pipefail
set -x
zero=$(readlink -f "$0")
zerodir="${zero%/*}"
Main() {
	local db="$1" cand="$2" snap="$3"
	rm -vf "$db"
	sqlite3 "$db" --init <(Init "$cand" "$snap" "$zerodir/../load/ncv/ncvoter_Statewide.sqlite3")
}
Init() {
	cat << EEOOTT
.bail on
.headers on
.timer on
.echo on
ATTACH DATABASE '$1' AS cand;
ATTACH DATABASE '$2' as snap;
-- Housekeeping from before TEMP views were found
DROP VIEW IF EXISTS snap.snapshot_dcand;

-- Unique list of candidates
CREATE TABLE IF NOT EXISTS unique_candidate AS
SELECT DISTINCT
election_dt
, contest_name
, name_on_ballot
FROM candidate
ORDER BY contest_name, name_on_ballot, election_dt
;
SELECT COUNT(1) AS unique_candidate FROM unique_candidate;

-- Create VIEW to aid dcand collation
CREATE TEMPORARY VIEW IF NOT EXISTS snapshot_dcand AS SELECT
county_desc
, voter_reg_num
, ncid
, last_name
, first_name
, midl_name
, name_sufx_cd
, zip_code
, party_cd
, registr_dt
FROM snap.snapshot
/*WHERE status_cd='A' */
;

-- Found candidates
CREATE TABLE IF NOT EXISTS found_candidate (
election_dt
, contest_name
, name_on_ballot
, county_desc
, voter_reg_num
, ncid
, last_name
, first_name
, midl_name
, name_sufx_cd
, zip_code
, party_cd
, registr_dt
, note
, PRIMARY KEY (
election_dt
, contest_name
, name_on_ballot
, county_desc
, voter_reg_num
, ncid
)
);

-- Missing
CREATE VIEW IF NOT EXISTS missing_candidate AS SELECT
unique_candidate.* FROM unique_candidate
NATURAL LEFT OUTER JOIN found_candidate
WHERE voter_reg_num IS NULL
ORDER BY contest_name, name_on_ballot, election_dt
;

-- nonpartisan 1

CREATE TABLE IF NOT EXISTS nonpartisan_1_candidate AS SELECT
unique_candidate.*
, county_name as county_desc
, last_name
, first_name
, middle_name as midl_name
, name_suffix_lbl as name_sufx_cd
, 'nonpartisan 1' as note
FROM unique_candidate
NATURAL JOIN candidate
WHERE is_partisan = 'FALSE'
ORDER BY contest_name, name_on_ballot, election_dt
;

-- find nonpartisan 1

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM nonpartisan_1_candidate
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
/* ORDER BY contest_name, name_on_ballot, election_dt*/
;

-- nonpartisan 2

CREATE TABLE IF NOT EXISTS nonpartisan_2_candidate AS SELECT
unique_candidate.*
, county_name as county_desc
, last_name
, first_name
, 'nonpartisan 2' as note
FROM missing_candidate
NATURAL JOIN unique_candidate
NATURAL JOIN candidate
WHERE is_partisan = 'FALSE'
ORDER BY contest_name, name_on_ballot, election_dt
;

-- find nonpartisan 2

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM nonpartisan_2_candidate
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
/* ORDER BY contest_name, name_on_ballot, election_dt */
;

-- nonpartisan 3

CREATE TABLE IF NOT EXISTS nonpartisan_3_candidate AS SELECT
unique_candidate.*
, county_name as county_desc
, last_name
, first_name
, middle_name
, 'nonpartisan 3' as note
FROM missing_candidate
NATURAL JOIN unique_candidate
NATURAL JOIN candidate
WHERE is_partisan = 'FALSE'
ORDER BY contest_name, name_on_ballot, election_dt
;

CREATE TEMP VIEW IF NOT EXISTS contest_district AS SELECT DISTINCT
contest_name
, substr(contest_name, instr(contest_name, 'CT ') + 3) as cdistrict
FROM unique_candidate
WHERE (
contest_name LIKE 'NC % DISTRICT %' OR
contest_name LIKE 'US % DISTRICT %'
)
;

-- ncsenate 1

CREATE TABLE IF NOT EXISTS ncsenate_1 AS
SELECT DISTINCT
unique_candidate.*
, county_name as county_desc
, last_name
, first_name
, middle_name as midl_name
, name_suffix_lbl as name_sufx_cd
, cdistrict as nc_senate_abbrv
, party_candidate as party_cd
, 'ncsenate 1' as note
FROM unique_candidate
NATURAL JOIN contest_district
NATURAL JOIN candidate
WHERE contest_name LIKE 'NC STATE SENATE %'
ORDER BY contest_name, name_on_ballot, election_dt
;

-- find ncsenate 1

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM ncsenate_1
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
;

-- ncsenate 2

CREATE TABLE IF NOT EXISTS ncsenate_2 AS
SELECT DISTINCT
unique_candidate.*
, county_desc
, last_name
, first_name
, nc_senate_abbrv
, party_cd
, 'ncsenate 2' as note
FROM ncsenate_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- find ncsenate 2

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM ncsenate_2
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
ORDER BY contest_name, name_on_ballot, election_dt
;

-- ncsenate 3

CREATE TABLE IF NOT EXISTS ncsenate_3 AS
SELECT DISTINCT
unique_candidate.*
, county_desc
, last_name
, first_name
, nc_senate_abbrv
, party_cd
, 'ncsenate 3' as note
FROM ncsenate_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- nchouse 1

CREATE TABLE IF NOT EXISTS nchouse_1 AS
SELECT DISTINCT
unique_candidate.*
, county_name as county_desc
, last_name
, first_name
, middle_name as midl_name
, name_suffix_lbl as name_sufx_cd
, cdistrict as nc_house_abbrv
, party_candidate as party_cd
, 'nchouse 1' as note
FROM unique_candidate
NATURAL JOIN contest_district
NATURAL JOIN candidate
WHERE contest_name LIKE 'NC HOUSE %'
ORDER BY contest_name, name_on_ballot, election_dt
;

-- find nchouse 1

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM nchouse_1
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
;

-- nchouse 2

CREATE TABLE IF NOT EXISTS nchouse_2 AS
SELECT DISTINCT
unique_candidate.*
, county_desc
, last_name
, first_name
, nc_house_abbrv
, party_cd
, 'nchouse 2' as note
FROM nchouse_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- find nchouse 2

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM nchouse_2
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
ORDER BY contest_name, name_on_ballot, election_dt
;

-- nchouse 3

CREATE TABLE IF NOT EXISTS nchouse_3 AS
SELECT DISTINCT
unique_candidate.*
, county_desc
, last_name
, first_name
, nc_house_abbrv
, party_cd
, 'nchouse 3' as note
FROM nchouse_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- ushouse 1

CREATE TABLE IF NOT EXISTS ushouse_1 AS
SELECT DISTINCT
unique_candidate.*
, last_name
, first_name
, middle_name as midl_name
, name_suffix_lbl as name_sufx_cd
, cdistrict as cong_dist_abbrv
, party_candidate as party_cd
, 'ushouse 1' as note
FROM unique_candidate
NATURAL JOIN contest_district
NATURAL JOIN candidate
WHERE contest_name LIKE 'US HOUSE %'
ORDER BY contest_name, name_on_ballot, election_dt
;

-- find ushouse 1

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM ushouse_1
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
;

-- ushouse 2

CREATE TABLE IF NOT EXISTS ushouse_2 AS
SELECT DISTINCT
unique_candidate.*
, last_name
, first_name
, cong_dist_abbrv
, party_cd
, 'ushouse 2' as note
FROM ushouse_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- find ushouse 2

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM ushouse_2
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
ORDER BY contest_name, name_on_ballot, election_dt
;

-- ushouse 3

CREATE TABLE IF NOT EXISTS ushouse_3 AS
SELECT DISTINCT
unique_candidate.*
, last_name
, first_name
, cong_dist_abbrv
, party_cd
, 'ushouse 3' as note
FROM ushouse_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- cjs 1

CREATE TABLE IF NOT EXISTS cjs_1 AS
SELECT DISTINCT
unique_candidate.*
, county_name as county_desc
, last_name
, first_name
, middle_name as midl_name
, name_suffix_lbl as name_sufx_cd
, party_candidate as party_cd
, 'cjs 1' as note
FROM unique_candidate
NATURAL JOIN candidate
WHERE (
contest_name LIKE '%COUNTY%' OR
contest_name LIKE '%JUDGE%' OR
contest_name LIKE '%SCHOOL%' OR
1
)
ORDER BY contest_name, name_on_ballot, election_dt
;

-- find cjs 1

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM cjs_1
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
;

-- cjs 2

CREATE TABLE IF NOT EXISTS cjs_2 AS
SELECT DISTINCT
unique_candidate.*
, county_desc
, last_name
, first_name
, party_cd
, 'cjs 2' as note
FROM cjs_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- find cjs 2

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note
FROM cjs_2
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand
ORDER BY contest_name, name_on_ballot, election_dt
;

-- cjs 3

CREATE TABLE IF NOT EXISTS cjs_3 AS
SELECT DISTINCT
unique_candidate.*
, county_desc
, last_name
, first_name
, party_cd
, 'cjs 3' as note
FROM cjs_1
NATURAL JOIN unique_candidate
NATURAL JOIN missing_candidate
;

-- final missing

CREATE TABLE IF NOT EXISTS final_missing AS
SELECT candidate.*
FROM missing_candidate
NATURAL JOIN candidate
ORDER BY contest_name, name_on_ballot, election_dt
;


EEOOTT
}
Main "$@"
exit 1
