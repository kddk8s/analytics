#!/bin/bash
set -e -u -o pipefail
set -x
zero=$(readlink -f "$0")
zerodir="${zero%/*}"
Main() {
	local db="$1" cand="$2" snap="$3"
	rm -vf "$db"
	sqlite3 "$db" --init <(Init "$cand" "$snap" "$zerodir/../load/ncv/ncvoter_Statewide.sqlite3") 
}
Init() {
	cat << EEOOTT
.bail on
.headers on
.timer on
.echo on
ATTACH DATABASE '$1' AS cand;
ATTACH DATABASE '$2' as snap;

-- Unique list of candidates
CREATE TABLE IF NOT EXISTS unique_candidate AS
SELECT DISTINCT
election_dt
, contest_name
, name_on_ballot
FROM candidate
ORDER BY election_dt, contest_name, name_on_ballot;
SELECT COUNT(1) AS unique_candidate FROM unique_candidate;

-- Create VIEW to aid dcand collation
CREATE VIEW IF NOT EXISTS snap.snapshot_dcand AS SELECT
county_desc
, voter_reg_num
, ncid
, last_name
, first_name
, midl_name
, name_sufx_cd
, zip_code
, party_cd
, registr_dt
FROM snap.snapshot
WHERE status_cd='A';

-- Found candidates
CREATE TABLE IF NOT EXISTS found_candidate (
election_dt
, contest_name
, name_on_ballot
, county_desc
, voter_reg_num
, ncid
, last_name
, first_name
, midl_name
, name_sufx_cd
, zip_code
, party_cd
, registr_dt
, note
, PRIMARY KEY (
election_dt
, contest_name
, name_on_ballot
, county_desc
, voter_reg_num
, ncid
)
);

-- Missing
CREATE VIEW IF NOT EXISTS missing_candidate AS SELECT
unique_candidate.* FROM unique_candidate
NATURAL LEFT OUTER JOIN found_candidate
WHERE voter_reg_num IS NULL;

-- nonpartisan

CREATE TABLE IF NOT EXISTS nonpartisan_candidate AS SELECT
unique_candidate.*
, county_name as county_desc 
, last_name
, first_name
, middle_name as midl_name
, name_suffix_lbl as name_sufx_cd
, 'non-partisan 1' as note
FROM unique_candidate
NATURAL JOIN candidate
WHERE is_partisan = 'FALSE';

-- find nonpartisan

INSERT OR IGNORE INTO found_candidate
SELECT unique_candidate.*, snapshot_dcand.*, note 
FROM nonpartisan_candidate
NATURAL JOIN unique_candidate
NATURAL JOIN snapshot_dcand;


EEOOTT
}
Main "$@"
exit 1
