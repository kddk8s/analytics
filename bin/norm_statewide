#!/bin/bash
set -e
set -u
set -x
set -o pipefail
Main(){
	local db="$1"; shift
	local ncvoter="$1"; shift
	local ncvhis="$1"; shift
	local sql
	if [ -z "${DEBUG:-}" ]; then
		sql=.quit
	fi
	rm -vf "$db"
	sqlite3 --init <(Setup "${ncvoter}" "${ncvhis}") "$db" ${sql:+$sql}
}
Setup() {
	cat << EEOOTT
.timer on
.echo on
.bail on
ATTACH DATABASE '$1' as ncvoter;
ATTACH DATABASE '$2' as ncvhis;
CREATE TABLE IF NOT EXISTS n_precincts (
  precinct_id INTEGER PRIMARY KEY
, county_id
, county_desc
, res_city_desc
, state_cd
, zip_code
, mail_city
, mail_state
, mail_zipcode
, precinct_abbrv
, precinct_desc
, municipality_abbrv
, municipality_desc
, vtd_abbrv
, vtd_desc
, zip_code_5 GENERATED ALWAYS AS (substr(zip_code, 1, 5)) STORED
);
CREATE UNIQUE INDEX IF NOT EXISTS n_precincts_u ON n_precincts (
  county_id
, county_desc
, res_city_desc
, state_cd
, zip_code
, mail_city
, mail_state
, mail_zipcode
, precinct_abbrv
, precinct_desc
, municipality_abbrv
, municipality_desc
, vtd_abbrv
, vtd_desc
);
INSERT OR IGNORE INTO n_precincts (
  county_id
, county_desc
, res_city_desc
, state_cd
, zip_code
, mail_city
, mail_state
, mail_zipcode
, precinct_abbrv
, precinct_desc
, municipality_abbrv
, municipality_desc
, vtd_abbrv
, vtd_desc
) SELECT DISTINCT
  county_id
, county_desc
, res_city_desc
, state_cd
, zip_code
, mail_city
, mail_state
, mail_zipcode
, precinct_abbrv
, precinct_desc
, municipality_abbrv
, municipality_desc
, vtd_abbrv
, vtd_desc
FROM l_ncvoterstatewide;
CREATE TABLE IF NOT EXISTS n_ncid_res (
  ncid_res_id INTEGER PRIMARY KEY
, precinct_id
, county_id
, voter_reg_num
, ncid
, res_street_address
, mail_addr1
, mail_addr2
, mail_addr3
, mail_addr4
);
CREATE UNIQUE INDEX IF NOT EXISTS n_ncid_res_u ON n_ncid_res (
  precinct_id
, county_id
, voter_reg_num
, ncid
, res_street_address
, mail_addr1
, mail_addr2
, mail_addr3
, mail_addr4
);
INSERT OR IGNORE INTO n_ncid_res (
  precinct_id
, county_id
, voter_reg_num
, ncid
, res_street_address
, mail_addr1
, mail_addr2
, mail_addr3
, mail_addr4
) SELECT DISTINCT
  precinct_id
, county_id
, voter_reg_num
, ncid
, res_street_address
, mail_addr1
, mail_addr2
, mail_addr3
, mail_addr4
FROM l_ncvoterstatewide NATURAL JOIN n_precincts;
CREATE TABLE IF NOT EXISTS n_demographics (
  demographic_id INTEGER PRIMARY KEY
, status_cd
, voter_status_desc
, reason_cd
, voter_status_reason_desc
, confidential_ind
, race_code
, ethnic_code
, party_cd
, gender_code
, birth_state
, drivers_lic
);
CREATE UNIQUE INDEX IF NOT EXISTS n_demographics_u (
  status_cd
, voter_status_desc
, reason_cd
, voter_status_reason_desc
, confidential_ind
, race_code
, ethnic_code
, party_cd
, gender_code
, birth_state
, drivers_lic
);
EEOOTT
}
Main "$@"
