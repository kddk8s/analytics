#!/bin/bash
set -e
set -u
set -o pipefail
# set -x
zero=$(readlink -f "$0")
zerodir="${zero%/*}"
db="${zerodir%/*}/load/ncv/ncvoter_Statewide.sqlite3"
declare -A expansion=(
	["cd"]=county_desc
	["pa"]=precinct_abbrv
	["rc"]=res_city_desc
	["rs"]=res_street
	["zc"]=zip_code
	)
Main() {
	local terms=(1) term lh rh operator q
	for term in "$@"; do
		lh="${term%%=*}"
		rh="${term#*=}"
		case "$rh" in
			*%*) operator=LIKE ;; 
			*) operator== ;;
		esac
		terms+=(AND "${expansion[${lh}]}" $operator "'${rh@U}'")
	done
	echo "${terms[*]}" 1>&2
	q="select * from precinct_street where ${terms[*]}"
	echo "$q" 1>&2
	sqlite3 "$db" ".header on" ${CSV:+".mode csv"} "$q"
}
Main "$@"
